{
  "name": "@logscopeai/logscope",
  "version": "1.0.0",
  "description": "Stable 1.0 Node.js SDK for sending application logs to the Logscope ingestion API.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pino": {
      "types": "./dist/pino.d.ts",
      "default": "./dist/pino.js"
    },
    "./winston": {
      "types": "./dist/winston.d.ts",
      "default": "./dist/winston.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky install",
    "format": "prettier --config .prettierrc --write .",
    "format:check": "prettier --config .prettierrc --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logscopeai/logscope.git"
  },
  "keywords": [
    "logscope",
    "logging",
    "sdk",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/logscopeai/logscope/issues"
  },
  "homepage": "https://github.com/logscopeai/logscope#readme",
  "dependencies": {
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "winston": "^3.19.0"
  },
  "lint-staged": {
    "*.{ts,js,tsx,jsx,html,css,scss,json,md}": [
      "npx prettier --config .prettierrc --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
